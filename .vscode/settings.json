{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "tailwindCSS.lint.invalidScreen": "off",
  "tailwindCSS.lint.invalidVariant": "off",
  "tailwindCSS.lint.invalidTailwindDirective": "off",
  "tailwindCSS.lint.cssConflict": "off",
  "tailwindCSS.lint.recommendedVariantOrder": "off",
  "[tailwindcss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "css.lint.unknownAtRules": "ignore",
  "css.lint.compatibleVendorPrefixes": "ignore",
  "css.validate": false,
  "scss.validate": false
}


